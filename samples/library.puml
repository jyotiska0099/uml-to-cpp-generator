@startuml

class Book {
  - title : string
  - author : string
  - isbn : string
  - isAvailable : bool
  + getTitle() : string
  + getAuthor() : string
  + getIsbn() : string
  + checkAvailability() : bool
}

class Member {
  - memberId : int
  - name : string
  - email : string
  - activeLoans : int
  + getMemberId() : int
  + getName() : string
  + getActiveLoans() : int
  + isEligibleToBorrow() : bool
}

class Loan {
  - loanId : int
  - dueDate : string
  - isReturned : bool
  + getLoanId() : int
  + getDueDate() : string
  + markReturned() : void
  + isOverdue() : bool
}

Member "1" -- "0..*" Loan
Book "1" -- "0..*" Loan

@enduml